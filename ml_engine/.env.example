# -------------------------------------------------------------
# ChurnGuard ML Engine Environment Variables (Production / DirectAdmin)
# -------------------------------------------------------------

# Supabase PostgreSQL Connection String (Highly recommended for production deployment)
DATABASE_URL=your_supabase_postgres_connection_string

# Fallback local SQLite DB Path (if DATABASE_URL is not set)
# Note: In isolated hosting environments, use DATABASE_URL (Supabase) instead.
SQLITE_DB_PATH=./churnguard.db
