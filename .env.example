# -------------------------------------------------------------
# ChurnGuard Environment Variables Example
# Copy this file to `.env` and fill in your Supabase credentials
# -------------------------------------------------------------

# Supabase PostgreSQL connection string (Transaction Mode - Port 6543)
# Format: postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
DATABASE_URL=

# Supabase REST API connection credentials (optional, for Supabase Client library)
SUPABASE_URL=
SUPABASE_KEY=

# Local SQLite configuration (used automatically as fallback if DATABASE_URL is empty)
# Node and Python will create and seed this database automatically.
# Keep relative to each folder or use absolute path.
SQLITE_DB_PATH=

# Port Configuration
PORT=8000
ML_PORT=5000
ML_ENGINE_URL=http://127.0.0.1:5000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Groq API Key for the Sophia Interactivity Assistant
GROQ_API_KEY=
