# -------------------------------------------------------------
# ChurnGuard Backend Environment Variables (Production / DirectAdmin)
# -------------------------------------------------------------

# Port for the Node.js application (DirectAdmin/Passenger handles this automatically)
PORT=8000

# URL of the Python ML Engine (running under its own subdomain in DirectAdmin)
# Example: https://churnguard-ml.rankia.cloud
ML_ENGINE_URL=https://churnguard-ml.rankia.cloud

# Comma-separated list of frontend origins allowed to call the API
# Example: https://central.rankia.cloud,https://staging-central.rankia.cloud,http://localhost:5173
CORS_ALLOWED_ORIGINS=https://central.rankia.cloud,http://localhost:5173,http://127.0.0.1:5173

# Supabase PostgreSQL Connection String (Highly recommended for production deployment)
DATABASE_URL=your_supabase_postgres_connection_string

# API key for the LLM agent provider (Groq)
GROQ_API_KEY=your_groq_api_key
